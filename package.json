      "validator@<13.15.20": ">=13.15.20",
      "tmp@<=0.2.3": ">=0.2.4",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "glob@>=11.0.0 <11.1.0": ">=11.1.0",
      "node-forge@<1.3.2": ">=1.3.2",
